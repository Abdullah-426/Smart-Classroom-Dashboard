# =============================================================================
# REFERENCE ONLY — NOT READ AUTOMATICALLY
# =============================================================================
# This file lives in the Smart Classroom *Dashboard* repo as documentation.
# Docker and Node-RED do NOT load it unless you copy these lines into YOUR OWN
# env file and pass that file when you create the container, e.g.:
#   docker run ... --env-file "E:\path\to\Smart Classroom\.env" ...
#
# Optional model lines: if omitted, the flow defaults to openai/gpt-oss-20b
# (and openai/gpt-oss-120b for highQuality/demo body flags).
# =============================================================================

# REQUIRED for live Groq (HTTPS only — never sent on MQTT or to the browser).
# In Function nodes, Node-RED reads these with env.get("GROQ_API_KEY") — not process.env
# (process is not available inside the Function VM). Docker -e / --env-file still sets OS env.
# CORRECT (one line, no spaces around =, no quotes):
#   GROQ_API_KEY=gsk_your_actual_key_here
#
# WRONG (Docker often ignores the variable or keeps quote characters in the key):
#   GROQ_API_KEY = "gsk_..."
#   GROQ_API_KEY="gsk_..."   # sometimes OK; plain form above is safest

GROQ_API_KEY=

# If Groq returns model errors, try: llama-3.3-70b-versatile
GROQ_MODEL=openai/gpt-oss-20b
GROQ_MODEL_HIGH_QUALITY=openai/gpt-oss-120b

# CLASSROOM_TIMEZONE=Asia/Dubai
